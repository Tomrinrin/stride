---
const links = [
  { href: "/", label: "Accueil" },
  { href: "/comparateur", label: "Comparateur" },
  { href: "/magazine", label: "Magazine" },
  { href: "/chaussures", label: "Chaussures" },
  { href: "/guides", label: "Guides" },
];
---

<header class="sticky top-0 z-50 bg-blanc/90 backdrop-blur border-b border-encre/10">
  <div class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between gap-3">
    <a href="/" class="flex items-center gap-2.5 whitespace-nowrap">
      <svg width="34" height="25" viewBox="0 0 110 80" aria-hidden="true" class="shrink-0">
        <path d="M22 14 L58 40 L22 66" fill="none" stroke="#FF4D2E" stroke-width="16" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M56 14 L92 40 L56 66" fill="none" stroke="#D6FF3C" stroke-width="16" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
      <span class="font-display font-black text-lg sm:text-2xl tracking-tight text-encre">Ma paire de <span class="text-corail">running</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm font-medium">
      {links.map((l) => (
        <a href={l.href} class="text-encre/70 hover:text-corail transition-colors">{l.label}</a>
      ))}
    </nav>

    <a
      href="/quiz"
      class="font-display font-bold text-sm bg-corail text-white px-4 py-2 rounded-lg hover:opacity-90 transition whitespace-nowrap"
    >
      Trouve ta paire
    </a>
  </div>
</header>

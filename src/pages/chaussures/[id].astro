---
import Base from "../../layouts/Base.astro";
import { shoes } from "../../data/shoes";

export function getStaticPaths() {
  return shoes.map((shoe) => ({
    params: { id: shoe.id },
    props: { shoe },
  }));
}

const { shoe } = Astro.props;
const usageLabel = shoe.usage === "route" ? "Route" : "Trail";
const img = shoe.image && shoe.image.length > 0 ? shoe.image : "/images/placeholder.svg";

const specs = [
  { label: "Drop", value: shoe.drop + " mm" },
  { label: "Poids", value: shoe.weight + " g" },
  { label: "Stack", value: shoe.stack + " mm" },
  { label: "Amorti", value: shoe.amorti },
  { label: "Prix indicatif", value: shoe.price + " €" },
];

const pageTitle = shoe.name + " — Ma paire de running";
---

<Base title={pageTitle} description={shoe.verdict}>
  <article class="mx-auto max-w-3xl px-5 py-16">
    <a href="/chaussures" class="text-sm font-medium text-bleu hover:underline">← Toutes les chaussures</a>

    <div class="mt-6 aspect-[16/9] bg-blanc rounded-2xl overflow-hidden flex items-center justify-center border border-encre/10">
      <img src={img} alt={shoe.name} class="w-full h-full object-contain p-4" />
    </div>

    <div class="mt-6 flex items-center gap-3">
      <span class="text-[11px] font-semibold uppercase tracking-wide px-2.5 py-1 rounded-full bg-bleu text-white">
        {usageLabel}
      </span>
      <span class="text-sm text-encre/50">{shoe.brand}</span>
    </div>

    <div class="mt-3 flex items-start justify-between gap-4">
      <h1 class="font-display font-black text-4xl md:text-5xl text-encre leading-tight">
        {shoe.name}
      </h1>
      <div class="shrink-0 text-center bg-volt rounded-2xl px-5 py-3">
        <div class="font-display font-black text-3xl text-encre leading-none">{shoe.score}</div>
        <div class="text-[10px] font-semibold uppercase tracking-wide text-encre/60 mt-1">Note</div>
      </div>
    </div>

    <p class="text-lg text-encre/70 mt-5 leading-relaxed">{shoe.verdict}</p>

    <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 gap-3">
      {specs.map((s) => (
        <div class="bg-white border border-encre/10 rounded-xl p-4">
          <div class="text-[11px] font-semibold uppercase tracking-wide text-encre/40">{s.label}</div>
          <div class="font-display font-extrabold text-xl text-encre mt-1">{s.value}</div>
        </div>
      ))}
    </div>

    <div class="mt-10">
      <a
        href="/comparateur"
        class="inline-block font-display font-bold bg-corail text-white px-6 py-3 rounded-xl hover:opacity-90 transition"
      >
        Comparer avec d'autres modèles
      </a>
    </div>
  </article>
</Base>

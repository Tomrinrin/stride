---
import Base from "../../layouts/Base.astro";
import { shoes } from "../../data/shoes";
import CatalogueChaussures from "../../components/CatalogueChaussures";
---

<Base title="Chaussures — Ma paire de running" description="Toutes nos fiches chaussures : filtre par marque, par usage, et tri par note, prix ou poids.">
  <section class="mx-auto max-w-6xl px-5 py-16">
    <p class="font-display font-bold text-xs tracking-[0.18em] uppercase text-corail">Chaussures</p>
    <h1 class="font-display font-black text-4xl md:text-5xl text-encre mt-3 mb-3">Toutes nos fiches.</h1>
    <p class="text-encre/60 mb-10 max-w-xl">
      Filtre par marque ou par usage, trie par note, prix ou poids. Clique sur une chaussure pour voir sa fiche complète.
    </p>

    <CatalogueChaussures client:load shoes={shoes} />
  </section>
</Base>

---
import Base from "../layouts/Base.astro";
import QuizChaussure from "../components/QuizChaussure.tsx";
---

<Base
  title="Trouve ta paire — Ma paire de running"
  description="Réponds à 6 questions et découvre les chaussures de running les plus adaptées à ta foulée, ton terrain et ton budget."
>
  <section class="bg-encre">
    <div class="mx-auto max-w-3xl px-5 py-14 md:py-20">
      <p class="font-display font-bold text-xs tracking-[0.18em] uppercase text-corail">Trouve ta paire</p>
      <h1 class="font-display font-black text-blanc text-4xl md:text-5xl leading-[0.95] tracking-tight mt-3">
        En 6 questions,<br />ta paire idéale.
      </h1>
      <p class="text-blanc/70 mt-4 max-w-xl">
        Pas le temps de comparer 50 modèles ? Réponds à quelques questions, on te sort les chaussures faites pour toi.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-12">
    <QuizChaussure client:load />
  </section>
</Base>
